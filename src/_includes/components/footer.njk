<footer>
    <div class="footer-img" style="height: 0">
        <!--
          <img style="border: black .1em solid;" src="/img/marcille.jpg" alt="me">
        -->
    </div>

    <div>

        {% for item in footer.links %}
            <span><a href="{{ item.link }}" rel="me"  target="_blank">{{ item.name }}</a></span>
            {% if not loop.last %}
                <span>|</span>
            {% endif %}
        {% endfor %}
    </div>
    <div>
        <p>credits: site base by <a href="https://maia.crimew.gay">maia</a></p>
    </div>
    <div class="badges">
        {% for item in footer.badges %}
            {% if item.link %}<a href="{{ item.link }}" target="_blank">{% endif %}<img src="/badges/{{ item.badge }}" alt="{{ item.alt }}" {% if item.title %}title="{{ item.title }}"{% endif %}>{% if item.link %}</a>{% endif %}
        {% endfor %}
    </div>
</footer>
